---
import BaseLayout from './BaseLayout.astro'

interface Props {
  title?: string
  activeRoute?: string
}

const { title } = Astro.props
const user = Astro.locals.user

const navItems = [
  { href: '/dashboard',     label: 'Dashboard',    icon: '◈' },
  { href: '/discover',      label: 'Discover',     icon: '⌖' },
  { href: '/verify',        label: 'Verify',       icon: '✓' },
  { href: '/compose',       label: 'Compose',      icon: '✎' },
  { href: '/campaigns',     label: 'Campaigns',    icon: '⊞' },
  { href: '/community-db',  label: 'Community DB', icon: '◎' },
  { href: '/warmup',        label: 'Warmup',       icon: '⟳' },
  { href: '/dns-wizard',    label: 'DNS Wizard',   icon: '⚡' },
  { href: '/keys',          label: 'API Keys',     icon: '⚿' },
]
---
<BaseLayout title={title}>
  <div class="min-h-screen flex text-sm">

    <!-- Sidebar -->
    <aside class="w-52 shrink-0 border-r border-[var(--border)] flex flex-col fixed h-full left-0 top-0">
      <!-- Brand -->
      <div class="px-4 py-5 border-b border-[var(--border)]">
        <span class="font-mono text-[var(--accent-purple)] text-xs tracking-widest">OUTREACHOS</span>
      </div>

      <!-- Nav -->
      <nav class="flex-1 py-3 overflow-y-auto">
        {navItems.map(({ href, label, icon }) => {
          const isActive = Astro.url.pathname === href
          return (
            <a
              href={href}
              class={`flex items-center gap-2.5 px-4 py-2 mx-2 rounded transition-colors font-mono text-xs ${
                isActive
                  ? 'bg-[var(--bg-elevated)] text-primary'
                  : 'text-secondary hover:text-primary hover:bg-[var(--bg-surface)]'
              }`}
            >
              <span class="w-4 text-center opacity-60">{icon}</span>
              {label}
            </a>
          )
        })}
      </nav>

      <!-- User + Logout -->
      {user && (
        <div class="border-t border-[var(--border)] p-3">
          <div class="flex items-center gap-2 mb-2">
            <img src={user.avatar} alt={user.name} class="w-6 h-6 rounded-full" />
            <div class="flex-1 min-w-0">
              <p class="text-primary text-xs truncate">{user.name}</p>
              <p class="text-secondary text-xs truncate">{user.email}</p>
            </div>
          </div>
          <a
            href="/api/auth/logout"
            class="block text-center text-xs text-secondary hover:text-[var(--accent-red)] font-mono py-1 border border-[var(--border)] hover:border-[var(--accent-red)] transition-colors"
          >
            Sign out
          </a>
        </div>
      )}
    </aside>

    <!-- Main content -->
    <div class="flex-1 ml-52">
      <!-- Top bar -->
      <header class="h-12 border-b border-[var(--border)] flex items-center px-6 sticky top-0 bg-[var(--bg-base)] z-10">
        <h1 class="text-primary font-sans font-medium">{title}</h1>
      </header>

      <!-- Page content -->
      <main class="p-6">
        <slot />
      </main>
    </div>

  </div>
</BaseLayout>