---
import BaseLayout from '@/layouts/BaseLayout.astro'
---
<BaseLayout title="Home">
  <div class="min-h-screen flex items-center justify-center">
    <div class="text-center">
      <p class="font-mono text-secondary text-sm mb-2">v0.1.0 — scaffolding complete</p>
      <h1 class="text-4xl font-sans font-medium text-primary">Pitch OS</h1>
      <p class="text-secondary mt-2">Your outreach. Your keys. Your community.</p>
      <a href="/login" class="inline-block mt-6 px-4 py-2 border border-[var(--border)] text-sm text-primary hover:bg-[var(--bg-surface)] transition-colors">
        Get started →
      </a>
    </div>
  </div>
</BaseLayout>