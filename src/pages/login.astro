---
import AuthLayout from '@/layouts/AuthLayout.astro'

const next = Astro.url.searchParams.get('next') || '/dashboard'
---
<AuthLayout title="Sign In">
  <div class="w-full max-w-sm">
    <!-- Logo / Brand -->
    <div class="text-center mb-8">
      <p class="font-mono text-[var(--accent-purple)] text-xs tracking-widest uppercase mb-2">
        Pitch OS
      </p>
      <h1 class="text-2xl text-primary font-sans font-medium">Welcome back</h1>
      <p class="text-secondary text-sm mt-1">Sign in to your workspace</p>
    </div>

    <!-- Google Sign In -->
    <a
      href={`/api/auth/google?next=${encodeURIComponent(next)}`}
      class="flex items-center justify-center gap-3 w-full px-4 py-3 border border-[var(--border)] text-primary text-sm hover:bg-[var(--bg-surface)] transition-colors group"
    >
      <!-- Google Icon SVG -->
      <svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
      </svg>
      <span>Continue with Google</span>
    </a>

    <!-- Divider -->
    <div class="flex items-center gap-3 my-6">
      <div class="flex-1 h-px bg-[var(--border)]"></div>
      <span class="text-xs text-secondary font-mono">BYOK · Open Source · Free</span>
      <div class="flex-1 h-px bg-[var(--border)]"></div>
    </div>

    <!-- Feature pills -->
    <div class="flex flex-wrap gap-2 justify-center">
      {['No data sold', 'Keys encrypted AES-256', 'Community powered', 'MIT License'].map(f => (
        <span class="text-xs text-secondary border border-[var(--border)] px-2 py-1 font-mono">{f}</span>
      ))}
    </div>

    <!-- Legal -->
    <p class="text-center text-xs text-secondary mt-8">
      By signing in you agree to use this tool for legitimate professional outreach only.
    </p>
  </div>
</AuthLayout>